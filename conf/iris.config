process {
    executor = 'slurm'
    queue = 'cmobic_cpu,cmobic_pipeline'
}

// additional genomes (override igenomes if present)
params {
    genomes {
        "hg19_local" {
            fasta            = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/H.sapiens/hg19/hg19.fasta"
            star             = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/H.sapiens/hg19/index/star/2.7.11b/gencode_v46lift37_gtf"
            gtf              = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/H.sapiens/gencode/v46lift37/gencode.v46lift37.annotation.gtf"
            transcript_fasta = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/H.sapiens/gencode/v46lift37/gencode.v46lift37.transcripts.fa"
            mito_name        = "chrM"
            macs_gsize       = "2.7e9"
        }
        "hg38_local" {
            fasta            = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/H.sapiens/hg38/hg38.fasta"
            star             = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/H.sapiens/hg38/index/star/2.7.11b/gencode_v46_gtf"
            gtf              = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/H.sapiens/gencode/v46/gencode.v46.annotation.gtf"
            transcript_fasta = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/H.sapiens/gencode/v46/gencode.v46.transcripts.fa"
            macs_gsize       = "2.9e9"
        }
        "mm10_local" {
            fasta       = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/M.musculus/mm10/mm10.fasta"
            star        = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/M.musculus/mm10/index/star/2.7.11b/gencode_vM23_gtf"
            gtf         = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/M.musculus/gencode/vM23/gencode.vM23.annotation.gtf"
            transcript_fasta = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/M.musculus/gencode/vM23/gencode.vM23.transcripts.fa"
            mito_name   = "chrM"
            macs_gsize  = "2.6e9"
        }
        "mm39_local" {
            fasta            = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/M.musculus/mm39/mm39.fa"
            star             = "/data1/core001/rsrc/apps/bic-rnaseq/assemblies/M.musculus/mm39/index/star/2.7.11b/gencode_vM36_gtf"
            gtf              = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/M.musculus/gencode/vM36/gencode.vM36.annotation.gtf"
            transcript_fasta = "/data1/core001/rsrc/apps/bic-rnaseq/annotation/M.musculus/gencode/vM36/gencode.vM36.transcripts.fa"
            mito_name        = "chrM"
            macs_gsize       = "2.7e9"
        }
    }
}
